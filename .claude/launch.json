{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server (docs)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000", "--directory", "docs"],
      "port": 8000
    },
    {
      "name": "Python HTTP Server (root)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8001"],
      "port": 8001
    },
    {
      "name": "Node http-server (docs)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "docs", "-p", "8000"],
      "port": 8000
    },
    {
      "name": "Node http-server (root)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8001"],
      "port": 8001
    }
  ]
}
